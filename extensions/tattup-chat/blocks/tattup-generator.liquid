{% comment %}
  TattUp AI Generator Block
  Add this block to any page via the Theme Customizer.
  Requires: App Proxy configured at /apps/tattup → your Cloudflare Worker
{% endcomment %}

{% assign credit_product = all_products[block.settings.credit_product_handle] %}
{% assign tattoo_product = all_products[block.settings.tattoo_product_handle] %}
{% assign tattoo_variant_id = tattoo_product.variants.first.id %}

<div
  id="tattup-app"
  class="tattup-container"
  data-logged-in="{% if customer %}true{% else %}false{% endif %}"
  data-customer-id="{% if customer %}{{ customer.id }}{% endif %}"
  data-proxy-base="/apps/tattup"
  data-tattoo-variant-id="{% if tattoo_variant_id %}{{ tattoo_variant_id }}{% endif %}"
>
  {%- comment -%} ========== NOT LOGGED IN ========== {%- endcomment -%}
  {% unless customer %}
    <div class="tattup-login" id="tattup-login">
      <div class="tattup-login-card">
        <div class="tattup-login-icon">
          <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
            <path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/>
            <circle cx="12" cy="7" r="4"/>
          </svg>
        </div>
        <h2>{{ block.settings.login_heading | default: 'Sign in to Create Tattoos' }}</h2>
        <p>{{ block.settings.login_text | default: 'Create an account or sign in to start generating AI tattoo designs.' }}</p>
        <a href="{{ routes.account_login_url }}?return_url={{ request.path | url_encode }}" class="tattup-btn tattup-btn-primary">
          Sign In
        </a>
      </div>
    </div>
  {% endunless %}

  {%- comment -%} ========== LOGGED IN - GENERATOR ========== {%- endcomment -%}
  {% if customer %}
    <div class="tattup-main" id="tattup-main">
      {%- comment -%} Header {%- endcomment -%}
      <div class="tattup-header">
        <h1 class="tattup-title">{{ block.settings.heading | default: 'Create Your Next Ink' }}</h1>
        <p class="tattup-subtitle">{{ block.settings.subheading | default: 'Select a style, describe your vision, and let our AI models draft your masterpiece.' }}</p>
        <div class="tattup-credits-badge" id="tattup-credits-badge">
          <span class="tattup-credits-icon">&#9733;</span>
          <span id="tattup-credit-count">...</span> Credits
        </div>
      </div>

      {%- comment -%} Input Area {%- endcomment -%}
      <div class="tattup-input-card">
        <textarea
          id="tattup-prompt"
          class="tattup-textarea"
          placeholder="Describe your tattoo idea..."
          rows="3"
          maxlength="500"
        ></textarea>

        <div class="tattup-controls">
          <div class="tattup-selects">
            <select id="tattup-model" class="tattup-select">
              <option value="standard">Standard (1 Credit)</option>
              <option value="pro">Pro HD (2 Credits)</option>
            </select>
            <select id="tattup-style" class="tattup-select">
              <option value="">No specific style</option>
              <option value="blackwork">Blackwork</option>
              <option value="traditional">Traditional</option>
              <option value="neo-traditional">Neo-Traditional</option>
              <option value="watercolor">Watercolor</option>
              <option value="minimalist">Minimalist</option>
              <option value="geometric">Geometric</option>
              <option value="japanese">Japanese</option>
              <option value="tribal">Tribal</option>
              <option value="dotwork">Dotwork</option>
              <option value="sketch">Sketch / Line Art</option>
              <option value="realism">Realism</option>
            </select>
          </div>

          <button id="tattup-generate-btn" class="tattup-btn tattup-btn-primary tattup-btn-generate">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="tattup-btn-icon">
              <path d="M12 2L15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2z"/>
            </svg>
            <span id="tattup-generate-text">Generate</span>
          </button>
        </div>
      </div>

      {%- comment -%} Status indicator {%- endcomment -%}
      <div id="tattup-status" class="tattup-status" style="display:none;">
        <div class="tattup-spinner"></div>
        <span id="tattup-status-text">Generating your tattoo...</span>
      </div>

      {%- comment -%} Gallery {%- endcomment -%}
      <div class="tattup-gallery" id="tattup-gallery">
        <div class="tattup-gallery-empty" id="tattup-gallery-empty">
          <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1" opacity="0.4">
            <rect x="3" y="3" width="18" height="18" rx="2" ry="2"/>
            <circle cx="8.5" cy="8.5" r="1.5"/>
            <polyline points="21 15 16 10 5 21"/>
          </svg>
          <p>Your generated designs will appear here.</p>
        </div>
        <div class="tattup-gallery-grid" id="tattup-gallery-grid"></div>
      </div>
    </div>

    {%- comment -%} ========== BUY CREDITS MODAL ========== {%- endcomment -%}
    <div id="tattup-buy-modal" class="tattup-modal-overlay" style="display:none;">
      <div class="tattup-modal">
        <button class="tattup-modal-close" id="tattup-modal-close">&times;</button>
        <h2>Buy Credits</h2>
        <p class="tattup-modal-subtitle">Choose a credit package to continue creating.</p>

        {% if credit_product %}
          {%- comment -%} One-Time Packages {%- endcomment -%}
          <h3 class="tattup-package-heading">One-Time Purchase</h3>
          <div class="tattup-packages" id="tattup-packages-onetime">
            {% for variant in credit_product.variants %}
              {% if variant.title contains "Einmalkauf" %}
                <button
                  class="tattup-package-btn"
                  data-variant-id="{{ variant.id }}"
                  data-price="{{ variant.price | money }}"
                >
                  <span class="tattup-package-name">{{ variant.title }}</span>
                  <span class="tattup-package-price">{{ variant.price | money }}</span>
                </button>
              {% endif %}
            {% endfor %}
          </div>

          {%- comment -%} Subscription Packages (Abo) {%- endcomment -%}
          {% assign has_subscriptions = false %}
          {% for variant in credit_product.variants %}
            {% if variant.title contains "Abo" %}
              {% assign has_subscriptions = true %}
              {% break %}
            {% endif %}
          {% endfor %}

          {% if has_subscriptions %}
            <h3 class="tattup-package-heading">Monatsabo</h3>
            <div class="tattup-packages" id="tattup-packages-sub">
              {% for variant in credit_product.variants %}
                {% if variant.title contains "Abo" %}
                  <button
                    class="tattup-package-btn"
                    data-variant-id="{{ variant.id }}"
                    data-price="{{ variant.price | money }}"
                    {% if variant.selling_plan_allocations.size > 0 %}
                      data-selling-plan-id="{{ variant.selling_plan_allocations.first.selling_plan.id }}"
                    {% endif %}
                  >
                    <span class="tattup-package-name">{{ variant.title }}</span>
                    <span class="tattup-package-price">{{ variant.price | money }}/mo</span>
                  </button>
                {% endif %}
              {% endfor %}
            </div>
          {% endif %}
        {% else %}
          <p class="tattup-no-product">Credit packages are not available at the moment.</p>
        {% endif %}

        <div id="tattup-cart-status" class="tattup-cart-status" style="display:none;"></div>
      </div>
    </div>
  {% endif %}
</div>

{% schema %}
{
  "name": "TattUp AI Generator",
  "target": "section",
  "javascript": "tattup-chat.js",
  "stylesheet": "tattup-chat.css",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Create Your Next Ink"
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "Subheading",
      "default": "Select a style, describe your vision, and let our AI models draft your masterpiece."
    },
    {
      "type": "text",
      "id": "login_heading",
      "label": "Login Heading",
      "default": "Sign in to Create Tattoos"
    },
    {
      "type": "text",
      "id": "login_text",
      "label": "Login Text",
      "default": "Create an account or sign in to start generating AI tattoo designs."
    },
    {
      "type": "text",
      "id": "credit_product_handle",
      "label": "Credit Product Handle",
      "default": "credit-packages",
      "info": "The handle of the Shopify product used for credit purchases."
    },
    {
      "type": "text",
      "id": "tattoo_product_handle",
      "label": "Tattoo Design Product Handle",
      "default": "tattup-ai-tattoo-design",
      "info": "The handle of the free product customers add to cart when booking a tattoo design."
    }
  ]
}
{% endschema %}
